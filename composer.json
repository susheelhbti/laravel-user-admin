{
    "name": "susheelhbti/laravel-user-admin",
    "description": "A Laravel package for OTP-based authentication with full user management admin API.",
    "keywords": [
        "laravel",
        "otp",
        "authentication",
        "user-management",
        "sanctum",
        "admin"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Susheel Kumar",
            "email": "susheelhbti@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/mail": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0",
        "laravel/sanctum": "^3.0|^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Susheelhbti\\LaravelUserAdmin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Susheelhbti\\LaravelUserAdmin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Susheelhbti\\LaravelUserAdmin\\LaravelUserAdminServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "version": "2.0.0",
    "suggest": {
        "pragmarx/google2fa": "Required for TOTP two-factor authentication support."
    }
}